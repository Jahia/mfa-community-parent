JAHIA_IMAGE=${JAHIA_IMAGE:-ghcr.io/jahia/jahia-ee-dev:8-SNAPSHOT}
TESTS_IMAGE=${TESTS_IMAGE:-cypress/included:13.6.1}
MODULE_ID=${MODULE_ID:-mfa-totp-factor}
# Compose project name — keeps this stack isolated from sibling test harnesses.
COMPOSE_PROJECT_NAME=${COMPOSE_PROJECT_NAME:-mfa-totp-factor-tests}
# Host-published ports. Defaults are deliberately non-standard so this stack can run
# alongside another project's stack still bound to 8080/8000/1025/8025.
JAHIA_HTTP_PORT=${JAHIA_HTTP_PORT:-8090}
JAHIA_DEBUG_PORT=${JAHIA_DEBUG_PORT:-8001}
MAILPIT_SMTP_PORT=${MAILPIT_SMTP_PORT:-1035}
MAILPIT_UI_PORT=${MAILPIT_UI_PORT:-8035}
JAHIA_URL=${JAHIA_URL:-http://localhost:${JAHIA_HTTP_PORT:-8090}}
SUPER_USER_PASSWORD=${SUPER_USER_PASSWORD:-root1234}
JAHIA_LICENSE=${JAHIA_LICENSE:-""}
JAHIA_HOST=${JAHIA_HOST:-jahia}
SMTP_SERVER_URL=${SMTP_SERVER_URL:-smtp://smtp-server:1025}
# Host-side Mailpit UI (the cypress container is given the in-network address via -e).
MAILPIT_URL=${MAILPIT_URL:-http://localhost:${MAILPIT_UI_PORT:-8035}}
